generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FamilyMode {
  SOLO
  COUPLE
}

enum FamilyRole {
  ADMIN
  MEMBER
}

enum IncomeType {
  PRIMARY
  SECONDARY
  SIDE
}

enum BudgetKind {
  MASTER
  MONTHLY
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          FamilyRole @default(MEMBER)
  familyId      String?
  family        Family?    @relation(fields: [familyId], references: [id])
  incomes       Income[]
  managedSubCategories SubCategory[] @relation("SubCategoryManager")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Family {
  id         String     @id @default(cuid())
  name       String
  inviteCode String     @unique
  mode       FamilyMode @default(COUPLE)
  members    User[]
  incomes    Income[]
  budgets    Budget[]
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Budget {
  id            String   @id @default(cuid())
  name          String
  kind          BudgetKind
  periodKey     String
  familyId      String
  family        Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  categories    Category[]
  sourceBudgetId String?
  sourceBudget  Budget?  @relation("BudgetCopies", fields: [sourceBudgetId], references: [id], onDelete: SetNull)
  copiedBudgets Budget[] @relation("BudgetCopies")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([familyId, periodKey])
  @@index([familyId, kind])
}

model Income {
  id        String     @id @default(cuid())
  label     String
  amount    Float
  type      IncomeType
  periodKey String
  familyId  String
  family    Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([familyId, periodKey])
}

model Category {
  id            String        @id @default(cuid())
  name          String
  color         String        @default("#C9922B")
  icon          String?
  familyId      String
  family        Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  budgetId      String
  budget        Budget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  subCategories SubCategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([budgetId])
}

model SubCategory {
  id           String   @id @default(cuid())
  name         String
  budgetAmount Float    @default(0)
  note         String?
  managerId    String?
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  manager      User?    @relation("SubCategoryManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([managerId])
}

// ── NextAuth required ─────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
